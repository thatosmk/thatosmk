---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import MyImage from '../assets/thato-semoko-picture.png';
import SerobeImage from '../assets/serobe-logo-project.png';
---

<Layout>
	<section class="grid gap-12 py-16 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,2.2fr)] lg:items-start lg:gap-16 lg:py-24">
		<aside class="flex max-w-xs flex-col gap-5">
			<Image
				src={MyImage}
				alt="Thato Semoko"
				width={160}
				height={160}
				class="h-28 w-28 rounded-full object-cover object-top ring-2 ring-white/10 lg:h-32 lg:w-32"
			/>
			<div class="space-y-3">
				<h1 class="text-2xl font-semibold tracking-tight text-white lg:text-3xl">
					Thato Semoko
				</h1>
				<p class="text-sm leading-relaxed text-white/75 lg:text-base">
					Thato is a software engineer and entrepreneur with experience building
					products and leading tech teams across startups.
				</p>
			</div>
		</aside>

		<div class="flex flex-col gap-8 lg:gap-10">
			<h2 class="max-w-4xl text-4xl font-semibold leading-[1.1] tracking-tight text-white sm:text-5xl lg:text-6xl">
				Building software products and helping teams to build impactful products that users love
			</h2>
			<p class="max-w-2xl text-base leading-relaxed text-white/80 lg:text-lg">
				I am always solving problems through shipping impactful products, helping
				teams maximise the value from their technology investments, and helping
				startups move faster. I’m the founder and CEO of
				<a
					href="https://serobe.co.za/?utm_source=thatosmk-web"
					class="underline decoration-white/30 underline-offset-4 transition hover:decoration-white"
				>
					Serobe
				</a>
				, and a Tech Lead at AgrigateOne.
			</p>
		</div>
	</section>

	<section class="my-24 lg:my-36" id="products">
		<div class="mb-10 max-w-2xl lg:mb-14">
			<h2 class="text-2xl font-semibold tracking-tight text-white lg:text-4xl">
				Products I’ve built
			</h2>
			<p class="mt-4 text-base leading-relaxed text-white/70 lg:text-lg">
				Software I’ve shipped to solve real operational problems.
			</p>
		</div>

		<div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-3 lg:gap-12">
			<a
				href="https://serobe.co.za/?utm_source=thatosmk-web"
				class="group flex flex-col gap-5"
			>
				<div class="overflow-hidden rounded-3xl bg-white">
					<Image
						src={SerobeImage}
						alt="Serobe"
						class="aspect-[4/3] w-full object-contain p-10 transition duration-300 group-hover:scale-[1.02]"
					/>
				</div>
				<div class="space-y-2">
					<h3 class="text-xl font-semibold tracking-tight text-white lg:text-2xl">
						Serobe
					</h3>
					<p class="text-sm leading-relaxed text-white/70 lg:text-base">
						A smart student residence management system that helps university
						residences run day-to-day operations and tenant interactions online.
					</p>
				</div>
			</a>
		</div>
	</section>
</Layout>
